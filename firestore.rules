rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: authenticated users can read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Sessions: authenticated users can create and read sessions;
    // only the creator can update or delete their session
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.creator_uid;
    }

    // Issues: authenticated users can read and create issues;
    // only the creator can update or delete their issue
    match /issues/{issueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.creator_uid;
    }
  }
}
